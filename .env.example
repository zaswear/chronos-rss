# Variables de entorno para Chronos RSS en Vercel
# Copia este archivo como .env.local para desarrollo local con `vercel dev`

# --- GitHub OAuth App ---
# Crea la app en: https://github.com/settings/developers
GITHUB_CLIENT_ID=tu_client_id_aqui
GITHUB_CLIENT_SECRET=tu_client_secret_aqui

# --- Control de Acceso ---
# Solo este usuario de GitHub puede entrar
ALLOWED_GITHUB_USER=zaswear

# --- API de Gemini ---
# Obtén tu clave en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=tu_gemini_api_key_aqui

# --- Seguridad de Sesión ---
# Genera con: openssl rand -hex 32
JWT_SECRET=cadena_aleatoria_muy_larga_aqui
